{
  "name": "naqla-sehia/naqla-framework",
  "description": "A micro framework used by Naqla Sehia development team for PHP Back-end projects",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Fares Khalid",
      "email": "fareskhalid791@gmail.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.0",
    "phpmailer/phpmailer": "^6.5",
    "symfony/var-dumper": "^5.2",
    "vlucas/phpdotenv": "^5.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "App",
      "NaqlaSehia\\": "src"
    },
    "files": [
      "src/Support/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
